{
  "permissions": {
    "allow": [
      "PowerShell(winget install OpenJS.NodeJS.LTS --silent --accept-package-agreements --accept-source-agreements)",
      "PowerShell(Get-ChildItem -Path components -Recurse -File | Select-Object FullName | ForEach-Object { $_.FullName.Replace\\(\\(Get-Location\\).Path + '\\\\', ''\\) })",
      "PowerShell(Get-ChildItem -Path lib -Recurse -File | Select-Object FullName | ForEach-Object { $_.FullName.Replace\\(\\(Get-Location\\).Path + '\\\\', ''\\) })",
      "PowerShell(python --version)"
    ]
  }
}
